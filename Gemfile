source 'https://rubygems.org'

# Pins the same Jekyll version GitHub Pages runs in production.
# (jekyll-redirect-from, jekyll-feed, jekyll-seo-tag, jekyll-sitemap are all included.)
gem 'github-pages', '~> 232', group: :jekyll_plugins

# Local `jekyll serve` needs this:
gem 'webrick', '~> 1.8'

# Stdlib gems no longer bundled with Ruby >= 3.4 that Jekyll 3.x still requires.
gem 'csv'
gem 'base64'
gem 'bigdecimal'
gem 'logger'
